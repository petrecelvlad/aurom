{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sortaur",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "aurom-db",
      "database_id": "ab47c422-d403-4101-8b6b-bb3142ddd6ea",
      "migrations_dir": "migrations"
    }
  ],
  "observability": {
    "enabled": true
  }
}
